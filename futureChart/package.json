{
  "name": "future-chart",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5180",
    "dev:public": "vite --port 5180",
    "broker": "npm run dev --prefix ../services/future-chart-broker",
    "dev:stack": "concurrently -k -n broker,vite \"npm run broker\" \"vite --host 127.0.0.1 --port 5180\"",
    "dev:local": "concurrently -k -n broker,market,fts,vite \"npm run broker\" \"npm run dev --prefix ../services/nexus-market-api\" \"npm run start --prefix ../services/future-trade-admin\" \"vite --host 127.0.0.1 --port 5180\"",
    "dev:local:5181": "concurrently -k -n broker,market,fts,vite \"npm run broker\" \"npm run dev --prefix ../services/nexus-market-api\" \"npm run start --prefix ../services/future-trade-admin\" \"vite --host 127.0.0.1 --port 5181\"",
    "dev:app": "concurrently -k \"vite --host 127.0.0.1 --port 5180\" \"wait-on http://127.0.0.1:5180 && electron .\"",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 5180",
    "preview:public": "vite preview --host 0.0.0.0 --port 5180",
    "electron:pack": "npm run build && electron-builder --win --mac",
    "electron:win": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "lightweight-charts": "^5.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.21",
    "@types/react-dom": "^18.3.6",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.8.3",
    "vite": "^6.2.6",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.nexus.futurechart",
    "productName": "FutureChart",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.finance"
    }
  }
}
