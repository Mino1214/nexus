# 로컬 한 번에 띄우기: futureChart 에서 npm run dev:local
# (브로커 8787 + nexus-market-api 3001 + future-trade-admin 3020 + Vite 5180)

# macroServer·nexus-market-api·masterAdmin 과 동일 DB/API (로컬 마켓 API는 보통 3001)
VITE_API_BASE=http://127.0.0.1:3001

# 설정 시 로그인 = POST /api/market/auth/login + master_customer_entitlements 검사 (데모 로그인 비활성)
# master_catalog_modules.slug 와 동일해야 함 (예: hts_future_trade)
# VITE_HTS_MODULE_SLUG=hts_future_trade
#
# 시드 후 테스트 계정 (nexus-market-api 마이그레이션 — masterAdmin 고객 demo-tenant@nexus.local)
# 마켓 유저 htsdemo / HtsDemo12 → can_admin 으로 FX 마스터 UI
# 운영자 demo_op / OpDemo12 → demo-tenant.nexus.local 테넌트
# Market API만 따로 둘 때 (비우면 VITE_API_BASE 와 동일)
# VITE_MARKET_API_BASE=http://127.0.0.1:3001
# masterAdmin에 등록한 모듈 코드와 맞출 것
# VITE_MODULE_CODE=A-2

# masterAdmin·총마켓 URL (운영 콘솔 상단 바로가기, 선택)
# VITE_MASTER_ADMIN_URL=http://127.0.0.1:5173
# VITE_TOTAL_MARKET_URL=http://127.0.0.1:5174

# 중개 서버 WebSocket (npm run broker —prefix services/future-chart-broker)
VITE_BROKER_WS_URL=ws://127.0.0.1:8787

# HTS 운영(총판·유저 설정) — masterAdmin 연동 시 true + API 베이스
# VITE_FC_MASTERADMIN_SYNC=true
# VITE_FC_MASTERADMIN_API_BASE=http://127.0.0.1:3000

# FutureTrade HTS 전용 운영 API (services/future-trade-admin, 공용 DB + MODULE_CODE)
VITE_FUTURE_TRADE_ADMIN_BASE=http://127.0.0.1:3020
