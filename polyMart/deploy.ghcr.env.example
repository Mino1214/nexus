API_IMAGE=ghcr.io/your-org/polywatch-api
WEB_IMAGE=ghcr.io/your-org/polywatch-web
IMAGE_TAG=latest

WEB_ORIGIN=https://polywatch.example.com
JWT_SECRET=replace-with-a-long-random-secret
ADMIN_EMAILS=admin@example.com
ADMIN_USERNAMES=admin

POSTGRES_USER=polywatch
POSTGRES_PASSWORD=replace-postgres-password
POSTGRES_DB=polywatch
DATABASE_URL=postgresql://polywatch:replace-postgres-password@postgres:5432/polywatch
REDIS_URL=redis://redis:6379

API_PUBLIC_PORT=43221
WEB_PUBLIC_PORT=43220

GAMMA_API_URL=https://gamma-api.polymarket.com
CLOB_API_URL=https://clob.polymarket.com
DATA_API_URL=https://data-api.polymarket.com
DEEPL_API_KEY=
